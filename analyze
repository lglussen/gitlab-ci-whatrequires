#!/usr/bin/env python

import yaml
import argparse
from datetime import datetime

parser = argparse.ArgumentParser('analyze yaml output of whatrequires scan')
subparsers = parser.add_subparsers(dest='command', help='Sub-command help')
sort = subparsers.add_parser('sort')
sort.add_argument('file', help='yaml file generated by whatrequires')
args = parser.parse_args()

def date(x):
    try:
        return datetime.fromisoformat( x[1]['include']['last_run'] ).timestamp()
    except:
        return datetime.fromtimestamp(0).timestamp()

if args.command == None:
    print('valid commands: sort')
    exit()

yfilename = args.file
if args.command == 'sort':
    with open(yfilename, 'r') as ifile:
        y = yaml.safe_load(ifile)
        items = sorted(y.items(), key=lambda x: date(x))
        for item in items:
            print(f'{item[1]['include']["last_run"]:<24} ({item[1]["include"]["ref"]}) {item[0]}')
        

